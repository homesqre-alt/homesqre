# Homesqre — React Router (BrowserRouter) fallback for Apache
# Ensures deep links like /properties/abc and /projects/bangalore/.../...
# don't 404 on refresh by routing all non-file requests to index.html.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If the request is for index.html itself, serve it
  RewriteRule ^index\.html$ - [L]

  # If the requested file or directory exists on disk, serve it
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise, fall back to index.html (React Router takes over)
  RewriteRule . /index.html [L]
</IfModule>

# Long-cache the hashed static assets that CRA emits under /static/
<IfModule mod_headers.c>
  <FilesMatch "\.(?i:js|css|woff2?|ttf|otf|eot|svg|png|jpg|jpeg|gif|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # But never cache index.html — needed so users always get the latest build
  <Files "index.html">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </Files>
</IfModule>

# Gzip text assets if mod_deflate is available
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
